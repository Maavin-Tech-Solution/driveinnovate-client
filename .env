# VITE_API_URL=http://localhost:5000/api
VITE_API_URL=https://server.driveinnovate.in/api
# VITE_API_URL=https://driveinnovate-server.onrender.com/api

# Auto-logout after inactivity (in minutes)
VITE_INACTIVITY_TIMEOUT=10

# ── Service availability flags ──────────────────────────────────────────────
# Set to 'false' to replace the page with the subscription-required message.
VITE_RTO_SERVICE_ENABLED=false
VITE_CHALLAN_SERVICE_ENABLED=false

# ── Subscription messages (shown when the service is disabled) ───────────────
VITE_RTO_UNAVAILABLE_MSG=You are currently not subscribed for our RTO services. Please contact your dealer to subscribe your fleet for RTO document tracking and renewal alerts.
VITE_CHALLAN_UNAVAILABLE_MSG=You are currently not subscribed for our Challan tracking services. Please contact your dealer to subscribe your fleet for automated challan detection and management.
 